# herdr-floating-pane configuration.
#
# Copy to:
#   $(herdr plugin config-dir herdr-floating-pane)/floating-pane.toml

# Floating box size as a percentage of the Herdr host pane.
# Values are clamped to 20..100.
width_pct = 94
height_pct = 92

# Hints displayed in the floating pane border. The actual keybindings live in
# ~/.config/herdr/config.toml.
key_hint_workspace = "prefix+f"
key_hint_session = "prefix+shift+f"
key_hint_minimize = "prefix+cmd+z"

# Backdrop fill color around the floating box. This is drawn by the plugin; it
# is not a live dimmed view of your underlying Herdr panes.
backdrop = "#0d2b1d"

# Best-effort mouse forwarding for terminal apps inside the floating box.
forward_inner_mouse = true
